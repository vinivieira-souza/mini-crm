# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/generated/prisma

# Prisma & SQLite
# Ignora os arquivos físicos do banco de dados local para não vazar dados
*.db
*.db-journal
/prisma/dev.db
/prisma/dev.db-journal

# Ignora variáveis de ambiente locais do Prisma (caso você crie arquivos .env separados)
.env.local
.env.development.local
.env.test.local
.env.production.local